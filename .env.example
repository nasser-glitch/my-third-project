# Server-side only (Netlify Functions) — do NOT prefix with VITE_
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_service_role_key   # Supabase → Project Settings → API → service_role
FOOTBALL_API_KEY=your_football_data_api_key  # https://www.football-data.org/client/register

# Client-side (EmailJS public keys are safe to expose)
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_DRAW=your_draw_template_id
VITE_EMAILJS_TEMPLATE_FINAL=your_final_template_id

# Admin password (client-side check)
VITE_ADMIN_PASSWORD=your_admin_password
